// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Station {
  id        String   @id @default(uuid())
  name      String   @unique 
  code      String   @unique 
  city      String
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  routeStations RouteStation[]

  @@index([name])
  @@index([code])
  @@map("stations")
}

model Train {
  id          String   @id @default(uuid())
  trainNumber String   @unique // "12301"
  trainName   String // "Rajdhani Express"
  coachName   String   @default("AC")
  totalSeats  Int    // Total seats in the single coach
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seats     Seat[]
  route     Route?
  schedules Schedule[]

  @@map("trains")
}

enum SeatType {
  LOWER
  MIDDLE
  UPPER
  SIDE_LOWER
  SIDE_UPPER
}

model Seat {
  id         String   @id @default(uuid())
  trainId    String
  seatNumber Int // 1, 2, 3...
  seatType   SeatType // LOWER, MIDDLE, UPPER etc
  price      Float // Price for this seat type

  train Train @relation(fields: [trainId], references: [id], onDelete: Cascade)

  @@unique([trainId, seatNumber])
  @@map("seats")
}

model Route {
  id      String @id @default(uuid())
  trainId String @unique

  train         Train          @relation(fields: [trainId], references: [id], onDelete: Cascade)
  routeStations RouteStation[]

  @@map("routes")
}

model RouteStation {
  id                 String  @id @default(uuid())
  routeId            String
  stationId          String
  sequenceNumber     Int // 1, 2, 3... order of station in route
  arrivalTime        String? // "06:00"
  departureTime      String? // "06:10" (null for last station)
  distanceFromOrigin Float   @default(0) // in km, for pricing calculation

  route   Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([routeId, sequenceNumber])
  @@unique([routeId, stationId])
  @@map("route_stations")
}

model Schedule {
  id            String         @id @default(uuid())
  trainId       String
  departureDate DateTime       @db.Date // The date this train runs
  status        ScheduleStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  train Train @relation(fields: [trainId], references: [id], onDelete: Cascade)

  @@unique([trainId, departureDate])
  @@map("schedules")
}

enum ScheduleStatus {
  ACTIVE
  CANCELLED
}